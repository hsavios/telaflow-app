# TelaFlow Cloud API - Environment Variables

# Database Configuration
# For development (SQLite):
# DATABASE_URL=sqlite:///telaflow_cloud_api.db

# For production/staging (PostgreSQL):
DATABASE_URL=postgresql://telaflow:password@localhost:5432/telaflow_cloud

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CLOUD_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.telaflow.ia.br

# Export Configuration
TELAFLOW_PACK_EXPORT_DIR=./data/pack-exports

# Logging
SQLALCHEMY_ECHO=false

# OAuth Providers (Optional, for Fase 2)
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# GITHUB_OAUTH_CLIENT_ID=your-github-client-id  
# GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret

# Redis (Optional, for Fase 2)
# REDIS_URL=redis://localhost:6379/0
